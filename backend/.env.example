# 复制本文件为 .env 并填入真实值。.env 已被 .gitignore 忽略，不要提交。
#
# 注意：值中若含 # 号，必须用双引号包起来，否则 dotenv 会把 # 之后的内容
#       当成注释丢弃。例如 DB_PASSWORD=abc#123 会被解析成 abc，
#       正确写法是 DB_PASSWORD="abc#123"。
PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=""
DB_NAME=tanxiaozhilv

# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_JWT_EXPIRES_IN=2h

# 微信登录
#
# MOCK_WECHAT=true  模拟登录：code 传任意字符串都能登录，openid 取 mock_<code>。
#                   本地开发与联调都用这个，不需要填 AppID / Secret。
# MOCK_WECHAT=false 真实登录：调微信 jscode2session 换取 openid，
#                   必须填入正式的 WECHAT_APPID 与 WECHAT_SECRET。
#
# 不设置该变量时按真实登录处理，缺少 AppID 会直接返回 1001「微信配置缺失」。
MOCK_WECHAT=true
WECHAT_APPID=
WECHAT_SECRET=

# 管理员入口白名单（管理员/用户模式隔离）
# 逗号分隔的 openid 列表，命中者"我的"页才显示"数据管理"入口；留空=无人可见（安全默认）。
# ⚠ 只控制入口可见性，不下发权限——进后台仍需管理员密码换 adminToken，后台接口由后端校验。
# 正式上线填组员真实 openid（组员登录一次后查 users 表取 openid）；
# 本地 MOCK_WECHAT=true 时 openid=mock_<code>，用固定 code 登录后填 mock_<code> 即可自测。
ADMIN_OPENID_WHITELIST=

# AI 新生助手（T8）—— DeepSeek
# 到 https://platform.deepseek.com 注册、创建 API Key，填到这里。
# 不填时 /api/ask 会走降级（返回知识库资料或提示稍后再试），不会崩。
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions
# 内容安全额外屏蔽词（逗号分隔），可选；上线应改用微信 msgSecCheck
# MODERATION_WORDS=
