page {
    background: #F5F7FA;
  }
  
  .story-mode-container {
    padding: 40rpx 40rpx 60rpx;
    min-height: 100vh;
  }
  
  /* ===== 头部 ===== */
  .header-area {
    text-align: center;
    padding: 30rpx 0 50rpx;
  }
  
  .page-title {
    display: block;
    font-size: 48rpx;
    font-weight: bold;
    color: #2C3E50;
    margin-bottom: 12rpx;
  }
  
  .page-subtitle {
    font-size: 28rpx;
    color: #7F8C8D;
  }
  
  /* ===== 故事卡片列表 ===== */
  .story-list {
    display: flex;
    flex-direction: column;
    gap: 30rpx;
  }
  
  .story-card {
    background: #FFFFFF;
    border-radius: 24rpx;
    padding: 30rpx 30rpx 30rpx 24rpx;
    display: flex;
    align-items: center;
    gap: 24rpx;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
    position: relative;
    transition: transform 0.2s;
  }
  
  .story-card:active {
    transform: scale(0.98);
  }
  
  .story-card-left {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10rpx;
    flex-shrink: 0;
  }
  
  .story-icon {
    width: 80rpx;
    height: 80rpx;
    border-radius: 16rpx;
  }
  
  .story-badge {
    font-size: 20rpx;
    color: #FFFFFF;
    background: #4A90D9;
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
  }
  
  .story-badge-orange {
    background: #E67E22;
  }
  
  .story-card-right {
    flex: 1;
  }
  
  .story-name {
    display: block;
    font-size: 32rpx;
    font-weight: 600;
    color: #2C3E50;
    margin-bottom: 8rpx;
  }
  
  .story-desc {
    display: block;
    font-size: 26rpx;
    color: #7F8C8D;
    margin-bottom: 12rpx;
  }
  
  .story-tags {
    display: flex;
    gap: 16rpx;
  }
  
  .tag {
    font-size: 20rpx;
    padding: 4rpx 16rpx;
    border-radius: 20rpx;
  }
  
  .tag-blue {
    background: #EBF5FF;
    color: #4A90D9;
  }
  
  .tag-green {
    background: #E8F8F0;
    color: #27AE60;
  }
  
  .tag-orange {
    background: #FEF5E7;
    color: #E67E22;
  }
  
  .story-arrow {
    font-size: 40rpx;
    color: #B0BEC5;
    flex-shrink: 0;
  }
  
  /* ===== 底部操作按钮 ===== */
  .action-row {
    display: flex;
    gap: 30rpx;
    margin-top: 50rpx;
    padding: 0 20rpx;
  }
  
  .action-btn {
    flex: 1;
    background: #FFFFFF;
    border-radius: 20rpx;
    padding: 30rpx 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12rpx;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  }
  
  .action-btn:active {
    transform: scale(0.95);
  }
  
  .action-icon {
    width: 48rpx;
    height: 48rpx;
  }
  
  .action-btn text {
    font-size: 26rpx;
    color: #4A5568;
  }