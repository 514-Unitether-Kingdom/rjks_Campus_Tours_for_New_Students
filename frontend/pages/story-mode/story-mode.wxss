page { background:#f3f1eb; color:#1d2a27; } .page-shell{padding:64rpx 36rpx 72rpx}.hero{padding:44rpx 28rpx;background:#1f443c;color:#f8f4e9;border-radius:8rpx}.eyebrow{display:block;font-size:20rpx;letter-spacing:4rpx;opacity:.72}.hero-title{display:block;font-size:56rpx;font-weight:700;margin:20rpx 0}.hero-copy{font-size:26rpx;opacity:.85}.quick-row{display:flex;gap:20rpx;margin:24rpx 0}.quick-item{flex:1;padding:22rpx;background:#fffdf6;border-left:6rpx solid #d5a84b}.quick-no{display:block;color:#a47728;font-size:22rpx;margin-bottom:8rpx}.section-heading{display:flex;justify-content:space-between;margin:42rpx 0 20rpx;font-size:24rpx;color:#65706a}.section-heading text:first-child{font-size:34rpx;font-weight:700;color:#1d2a27}.route-list{height:680rpx}.route-card{display:flex;align-items:center;gap:22rpx;margin-bottom:18rpx;padding:28rpx 20rpx;background:#fffdf8;border-bottom:2rpx solid #d9d5c9}.process-map-card{background:#e4eee8;border-bottom-color:#1f443c}.route-index{font-family:serif;font-size:36rpx;color:#d5a84b}.process-map-card .route-index{font-family:inherit;font-size:23rpx;font-weight:700;color:#1f443c}.route-main{flex:1;min-width:0}.route-kind,.route-name,.route-desc,.route-meta{display:block}.route-kind{font-size:20rpx;letter-spacing:2rpx;color:#8b7650}.route-name{font-size:34rpx;font-weight:700;margin:8rpx 0}.route-desc{font-size:25rpx;color:#59655f;line-height:1.5}.route-meta{font-size:21rpx;color:#9a8b6f;margin-top:12rpx}.route-arrow{font-size:36rpx}.loading,.notice,.empty{padding:80rpx 20rpx;text-align:center;color:#65706a}.retry{display:block;color:#1f443c;margin-top:18rpx;text-decoration:underline}
