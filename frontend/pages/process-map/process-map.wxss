page{background:#eef2f0;color:#172d28}.map-page{min-height:100vh;padding:56rpx 30rpx 72rpx;box-sizing:border-box}.map-head{padding:16rpx 8rpx 36rpx}.eyebrow{display:block;font-size:20rpx;letter-spacing:4rpx;color:#80938b}.title{display:block;font-size:52rpx;font-weight:700;margin:18rpx 0}.subtitle{font-size:26rpx;color:#64766f}.map-card{position:relative;overflow:hidden;border-radius:20rpx;background:#fff;box-shadow:0 10rpx 28rpx rgba(23,45,40,.1)}.campus-map{display:block;width:100%}.map-marker{position:absolute;transform:translate(-50%,-100%);display:flex;flex-direction:column;align-items:center;z-index:2}.marker-pin{width:58rpx;height:58rpx;border-radius:50% 50% 50% 0;transform:rotate(-45deg);background:#d49f34;box-shadow:0 6rpx 12rpx rgba(69,53,23,.28);display:flex;align-items:center;justify-content:center}.marker-pin.completed{background:#2f8067}.marker-pin text{transform:rotate(45deg);font-size:32rpx;color:#fff;font-weight:700}.marker-label{max-width:180rpx;margin-top:12rpx;padding:8rpx 12rpx;background:rgba(23,45,40,.88);border-radius:8rpx;color:#fff;font-size:21rpx;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.loading,.notice{padding:120rpx 20rpx;text-align:center;color:#65766f}.retry{display:block;color:#1f6250;margin-top:18rpx;text-decoration:underline}.empty-map{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.72);font-size:26rpx;color:#65766f}
