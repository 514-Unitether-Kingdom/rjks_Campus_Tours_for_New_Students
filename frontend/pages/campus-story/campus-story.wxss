.story-page{height:100vh;overflow:hidden;position:relative;background:#152820;color:#fff}.scene,.shade{position:absolute;width:100%;height:100%;inset:0}.shade{background:linear-gradient(180deg,rgba(5,12,10,.65),transparent 45%,rgba(5,12,10,.9))}.topbar{position:absolute;z-index:2;top:0;left:0;right:0;padding:112rpx 30rpx 28rpx;font-size:28rpx;letter-spacing:1rpx}.character{position:absolute;z-index:1;right:20rpx;bottom:310rpx;width:360rpx;height:460rpx}.chapter-marker{position:absolute;z-index:4;left:0;right:0;bottom:338rpx;text-align:center;font-size:22rpx;letter-spacing:3rpx;color:#e4c36c;text-shadow:0 2rpx 8rpx #000}.story-copy{position:absolute;z-index:3;bottom:0;left:0;right:0;padding:32rpx 34rpx calc(42rpx + env(safe-area-inset-bottom));background:rgba(10,24,19,.9);border-top:1rpx solid rgba(228,195,108,.5)}.speaker,.words,.copy-foot{display:block}.speaker{font-size:32rpx;color:#e4c36c;letter-spacing:2rpx;font-weight:600;margin-bottom:18rpx}.words{font-size:34rpx;line-height:1.7;min-height:126rpx}.copy-foot{display:flex;align-items:center;gap:18rpx;margin-top:26rpx;font-size:28rpx;color:#d1ddd6}.review,.save,.next{padding:12rpx 0}.save{padding:12rpx 20rpx;border:1rpx solid rgba(228,195,108,.72);color:#f0cf79}.next{margin-left:auto;color:#d1ddd6}
