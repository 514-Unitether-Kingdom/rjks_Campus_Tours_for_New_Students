<view class="story-page"><image class="scene" src="{{currentNode.bg || '/images/story_bg_default.jpg'}}" mode="aspectFill"></image><view class="shade"></view><view class="topbar"><text bindtap="goBack">← 离开</text></view><image class="character" src="{{currentNode.characterImage}}" mode="aspectFit" wx:if="{{currentNode.characterImage}}"></image><view class="story-copy" bindtap="onTap"><text class="chapter-marker">CAMPUS / {{currentIndex + 1}}</text><text class="speaker">{{currentNode.character || '校园提示'}}</text><text class="words">{{currentNode.text}}</text><view class="copy-foot"><text class="review" catchtap="showHistory">回顾</text><text class="save" catchtap="onSave">保存进度</text><text class="next" wx:if="{{isEnding}}">正在记录…</text><text class="next" wx:elif="{{currentNode.isEnd}}">点击完成 →</text><text class="next" wx:else>轻触继续 →</text></view></view></view>
