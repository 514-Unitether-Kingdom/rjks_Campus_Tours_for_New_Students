<view class="badge-page"><view class="badge-hero"><text class="eyebrow">YOUR COLLECTION</text><text class="count">{{obtainedCount}}</text><text class="count-label">枚校园记忆已收集</text></view><view class="loading" wx:if="{{loading}}">正在打开收藏册…</view><view class="notice" wx:elif="{{loadError}}"><text>{{loadError}}</text><text class="retry" bindtap="loadBadges">重新加载</text></view><view class="badge-grid" wx:else><view class="badge-tile {{item.obtained ? 'earned' : 'locked'}}" wx:for="{{badges}}" wx:key="id"><view class="badge-image-wrap"><image src="{{item.icon}}" class="badge-image" mode="aspectFit"></image></view><text class="badge-name">{{item.name}}</text><text class="badge-desc">{{item.description}}</text><text class="badge-state">{{item.obtained ? '已收藏' : '尚未解锁'}}</text></view></view><view class="explore" bindtap="goToStoryMode">去探索更多校园故事 →</view></view>
