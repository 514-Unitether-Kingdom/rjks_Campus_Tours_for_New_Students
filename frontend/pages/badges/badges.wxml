<view class="badges-container">
  <view class="header-area">
    <text class="page-title">🏅 我的勋章</text>
    <text class="page-subtitle">完成剧情收集勋章</text>
    <text class="badge-count">已获得 {{obtainedCount}} / {{badges.length}} 枚</text>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>⏳ 加载中...</text>
  </view>

  <!-- 勋章网格 -->
  <view class="badges-grid" wx:elif="{{badges.length > 0}}">
    <view class="badge-card {{item.obtained ? 'obtained' : 'locked'}}" wx:for="{{badges}}" wx:key="id">
      <view class="badge-icon-wrapper {{item.obtained ? 'obtained' : 'locked'}}">
        <!-- 已获得：显示彩色勋章图标；未获得：显示灰色占位图 -->
        <image class="badge-icon" 
               src="{{item.obtained ? item.icon : '/images/badge_gray.png'}}" 
               mode="aspectFit">
        </image>
        <!-- 已获得标记 -->
        <view class="badge-status" wx:if="{{item.obtained}}">
          <text class="status-text">✓</text>
        </view>
        <!-- 已获得发光效果 -->
        <view class="badge-glow" wx:if="{{item.obtained}}"></view>
      </view>
      
      <text class="badge-name">{{item.name}}</text>
      <text class="badge-desc">{{item.description || '探索中...'}}</text>
      
      <!-- 状态标签 -->
      <view class="badge-status-label {{item.obtained ? 'obtained-label' : 'locked-label'}}">
        <text>{{item.obtained ? '✅ 已获得' : '🔒 未获得'}}</text>
      </view>
      
      <!-- 未获得时显示提示 -->
      <text class="badge-hint" wx:if="{{!item.obtained}}">完成对应剧情解锁</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">🎯</text>
    <text class="empty-title">暂未获得任何勋章</text>
    <text class="empty-desc">快去故事模式完成剧情吧！</text>
    <button class="btn-go-story" bindtap="goToStoryMode">去故事模式 →</button>
  </view>
</view>