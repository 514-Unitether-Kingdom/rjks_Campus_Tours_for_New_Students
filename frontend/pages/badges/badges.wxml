<view class="badge-page"><view class="badge-hero"><text class="eyebrow">YOUR COLLECTION</text><text class="count" data-testid="badge-count">{{obtainedCount}}</text><text class="count-label">枚校园记忆已收集</text></view><view class="loading" wx:if="{{loading}}">正在打开收藏册…</view><view class="notice" wx:elif="{{loadError}}"><text>{{loadError}}</text><text class="retry" data-testid="badges-retry" bindtap="loadBadges">重新加载</text></view><view class="badge-grid" wx:else><view class="badge-tile {{item.obtained ? 'earned' : 'locked'}} {{item.detail ? 'has-detail' : ''}}" data-testid="badge-tile" data-detail="{{item.detail}}" bindtap="showBadgeDetail" wx:for="{{badges}}" wx:key="id"><view class="badge-image-wrap"><image src="{{item.icon}}" class="badge-image" mode="aspectFit"></image></view><text class="badge-name">{{item.name}}</text><text class="badge-desc">{{item.description}}</text><text class="badge-state">{{item.obtained ? '已收藏' : '尚未解锁'}}</text><text class="badge-detail-hint" wx:if="{{item.detail}}">点击查看开放信息</text></view></view><view class="explore" data-testid="badges-go-story" bindtap="goToStoryMode">去探索更多校园故事 →</view></view>
