page{background:#192c2a;color:#f8f2df}.badge-page{min-height:100vh;padding:64rpx 32rpx;box-sizing:border-box}.badge-hero{text-align:center;padding:30rpx 0 52rpx}.eyebrow{display:block;font-size:20rpx;letter-spacing:4rpx;color:#a9bbb1}.count{display:block;font-family:serif;font-size:128rpx;line-height:1;color:#d7ad52;margin:18rpx}.count-label{font-size:26rpx;color:#d6dfd8}.badge-grid{display:grid;grid-template-columns:1fr 1fr;gap:20rpx}.badge-tile{min-height:310rpx;padding:24rpx 18rpx;box-sizing:border-box;background:#24423d;border:1rpx solid #3c5b54}.badge-tile.locked{background:#223632;opacity:.68}.badge-image-wrap{height:110rpx;text-align:center}.badge-image{width:100rpx;height:100rpx}.badge-name,.badge-desc,.badge-state{display:block}.badge-name{font-size:28rpx;font-weight:700;margin:18rpx 0 8rpx}.badge-desc{font-size:21rpx;line-height:1.45;color:#bdd0c5}.badge-state{font-size:20rpx;color:#d7ad52;margin-top:16rpx}.locked .badge-image{filter:grayscale(1)}.loading,.notice{padding:100rpx 20rpx;text-align:center;color:#d6dfd8}.retry{display:block;color:#d7ad52;margin-top:18rpx}.explore{text-align:center;margin:52rpx 0 24rpx;font-size:26rpx;color:#d7ad52}
