page {
    background: linear-gradient(180deg, #F0F7FF 0%, #FFFFFF 100%);
    min-height: 100vh;
  }
  
  .admin-login-container {
    padding: 60rpx 50rpx 80rpx;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
  
  /* ===== 头部 ===== */
  .header-area {
    text-align: center;
    padding: 40rpx 0 50rpx;
  }
  
  .icon-wrapper {
    width: 120rpx;
    height: 120rpx;
    background: linear-gradient(135deg, #4A90D9, #357ABD);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 30rpx;
    box-shadow: 0 8rpx 32rpx rgba(74, 144, 217, 0.3);
  }
  
  .lock-icon {
    font-size: 56rpx;
  }
  
  .page-title {
    display: block;
    font-size: 44rpx;
    font-weight: bold;
    color: #2C3E50;
    margin-bottom: 12rpx;
  }
  
  .page-subtitle {
    font-size: 28rpx;
    color: #7F8C8D;
  }
  
  /* ===== 登录卡片 ===== */
  .login-card {
    background: #FFFFFF;
    border-radius: 24rpx;
    padding: 40rpx 36rpx 50rpx;
    box-shadow: 0 4rpx 30rpx rgba(0, 0, 0, 0.06);
    flex: 1;
  }
  
  .form-item {
    margin-bottom: 36rpx;
  }
  
  .label {
    display: block;
    font-size: 28rpx;
    color: #4A5568;
    font-weight: 500;
    margin-bottom: 12rpx;
  }
  
  .input {
    width: 100%;
    height: 80rpx;
    border-bottom: 2rpx solid #E8EEF5;
    font-size: 30rpx;
    padding: 0 10rpx;
    color: #2D3748;
    transition: border-color 0.3s;
  }
  
  .input:focus {
    border-bottom-color: #4A90D9;
  }
  
  .input::placeholder {
    color: #B0BEC5;
  }
  
  /* ===== 错误提示 ===== */
  .error-tip {
    background: #FEE2E2;
    border-radius: 12rpx;
    padding: 16rpx 20rpx;
    margin-bottom: 30rpx;
  }
  
  .error-text {
    font-size: 26rpx;
    color: #E74C3C;
  }
  
  /* ===== 登录按钮 ===== */
  .btn-login {
    width: 100%;
    height: 88rpx;
    line-height: 88rpx;
    background: linear-gradient(135deg, #4A90D9 0%, #357ABD 100%);
    color: #FFFFFF;
    border: none;
    border-radius: 44rpx;
    font-size: 34rpx;
    font-weight: 500;
    letter-spacing: 4rpx;
    box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.3);
    transition: all 0.3s;
  }
  
  .btn-login:active {
    transform: scale(0.98);
    opacity: 0.9;
  }
  
  .btn-login::after {
    border: none;
  }
  
  .btn-login[disabled] {
    opacity: 0.6;
  }
  
  /* ===== 提示信息 ===== */
  .hint-area {
    margin-top: 30rpx;
    text-align: center;
  }
  
  .hint-text {
    font-size: 24rpx;
    color: #B0BEC5;
  }
  
  /* ===== 底部返回 ===== */
  .footer {
    text-align: center;
    padding: 40rpx 0 20rpx;
  }
  
  .footer-text {
    font-size: 28rpx;
    color: #7F8C8D;
    padding: 10rpx 30rpx;
  }
  
  .footer-text:active {
    opacity: 0.6;
  }