<view class="admin-login-container">
  <view class="header-area">
    <view class="icon-wrapper">
      <text class="lock-icon">🔐</text>
    </view>
    <text class="page-title">管理员登录</text>
    <text class="page-subtitle">请输入管理员账号密码</text>
  </view>

  <view class="login-card">
    <view class="form-item">
      <text class="label">👤 用户名</text>
      <input class="input" 
             placeholder="请输入用户名" 
             bindinput="onUserInput" 
             value="{{username}}"
             maxlength="20"/>
    </view>

    <view class="form-item">
      <text class="label">🔑 密码</text>
      <input class="input" 
             placeholder="请输入密码" 
             bindinput="onPwdInput" 
             value="{{password}}"
             password
             maxlength="20"/>
    </view>

    <view class="error-tip" wx:if="{{errorMsg}}">
      <text class="error-text">❌ {{errorMsg}}</text>
    </view>

    <button class="btn-login" bindtap="login" disabled="{{loading}}">
      {{loading ? '登录中...' : '登 录'}}
    </button>

    <view class="hint-area">
      <text class="hint-text">💡 默认账号：admin / 密码：123456</text>
    </view>
  </view>

  <view class="footer" bindtap="goBack">
    <text class="footer-text">← 返回我的页面</text>
  </view>
</view>