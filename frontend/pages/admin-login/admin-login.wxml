<view class="login-page"><view class="login-hero"><text class="eyebrow">RESTRICTED AREA</text><text class="title">数据管理入口</text><text class="subtitle">请使用管理员凭据继续。</text></view><view class="form"><text class="field-label">管理员账号</text><input class="field" placeholder="输入账号" bindinput="onUserInput" value="{{username}}" maxlength="40"/><text class="field-label">密码</text><input class="field" placeholder="输入密码" bindinput="onPwdInput" value="{{password}}" password maxlength="80"/><text class="error" wx:if="{{errorMsg}}">{{errorMsg}}</text><button class="submit" bindtap="login" disabled="{{loading}}">{{loading ? '正在验证…' : '验证并进入'}} →</button></view><text class="back" bindtap="goBack">← 返回个人页面</text></view>
