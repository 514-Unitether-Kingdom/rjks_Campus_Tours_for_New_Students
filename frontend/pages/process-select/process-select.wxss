page{background:#eef2f0;color:#172d28}.process-page{padding:64rpx 36rpx}.process-hero{padding:24rpx 0 44rpx}.eyebrow{display:block;font-size:20rpx;letter-spacing:4rpx;color:#80938b}.title{display:block;font-size:52rpx;font-weight:700;margin:18rpx 0}.subtitle{font-size:26rpx;color:#64766f}.process-list{display:flex;flex-direction:column;gap:18rpx}.process-card{display:flex;align-items:center;padding:28rpx 24rpx;background:#fff;border-radius:18rpx;box-shadow:0 10rpx 24rpx rgba(23,45,40,.06)}.status-dot{width:18rpx;height:18rpx;border-radius:50%;background:#d4a341;margin-right:22rpx}.status-dot.done{background:#39846b}.process-body{flex:1}.process-name,.process-desc,.process-count{display:block}.process-name{font-size:32rpx;font-weight:700}.process-desc{font-size:25rpx;color:#65766f;margin:8rpx 0}.process-count{font-size:21rpx;color:#9aaa9f}.arrow{font-size:32rpx}.loading,.notice,.empty{padding:100rpx 20rpx;text-align:center;color:#65766f}.retry{display:block;color:#1f6250;margin-top:18rpx}.sheet-mask{position:fixed;inset:0;background:rgba(13,31,26,.45);z-index:9;display:flex;align-items:flex-end}.sheet{width:100%;max-height:80vh;box-sizing:border-box;overflow:auto;background:#fff;border-radius:36rpx 36rpx 0 0;padding:22rpx 38rpx calc(40rpx + env(safe-area-inset-bottom))}.sheet-handle{width:66rpx;height:8rpx;background:#d7dfda;border-radius:10rpx;margin:0 auto 30rpx}.sheet-title,.sheet-desc{display:block}.sheet-title{font-size:40rpx;font-weight:700}.sheet-desc{font-size:25rpx;color:#65766f;margin:14rpx 0 28rpx}.step{display:flex;gap:18rpx;margin:20rpx 0;font-size:26rpx;line-height:1.5}.step-no{color:#b17c22;font-weight:bold}.enter{margin-top:24rpx;background:#1f6250;color:#fff;border-radius:8rpx;font-size:30rpx}.enter:after{border:0}
