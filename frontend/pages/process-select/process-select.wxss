page {
    background: #F5F7FA;
  }
  
  .process-container {
    padding: 30rpx 30rpx 60rpx;
    min-height: 100vh;
  }
  
  /* ===== 头部 ===== */
  .header-area {
    text-align: center;
    padding: 20rpx 0 30rpx;
  }
  
  .page-title {
    display: block;
    font-size: 44rpx;
    font-weight: bold;
    color: #2C3E50;
    margin-bottom: 8rpx;
  }
  
  .page-subtitle {
    font-size: 26rpx;
    color: #7F8C8D;
  }
  
  /* ===== 地图区域 ===== */
  .map-wrapper {
    position: relative;
    background: #FFFFFF;
    border-radius: 24rpx;
    overflow: hidden;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  }
  
  .map-bg {
    width: 100%;
    display: block;
  }
  
  /* ===== 标记点 ===== */
  .marker {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: translate(-50%, -50%);
  }
  
  .marker-medical {
    top: 55%;
    left: 28%;
  }
  
  .marker-card {
    top: 45%;
    left: 55%;
  }
  
  .marker-print {
    top: 65%;
    left: 70%;
  }
  
  .marker-icon {
    width: 60rpx;
    height: 60rpx;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28rpx;
    box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
    transition: transform 0.3s;
  }
  
  .marker-icon:active {
    transform: scale(1.15);
  }
  
  .marker-icon.pending {
    background: #FF6B6B;
    border: 3rpx solid #FFFFFF;
    animation: pulse 1.5s ease-in-out infinite;
  }
  
  .marker-icon.completed {
    background: #27AE60;
    border: 3rpx solid #FFFFFF;
  }
  
  @keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }
  
  .marker-label {
    font-size: 20rpx;
    color: #2C3E50;
    background: rgba(255, 255, 255, 0.9);
    padding: 4rpx 12rpx;
    border-radius: 12rpx;
    margin-top: 6rpx;
    box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  }
  
  /* ===== 弹窗 ===== */
  .popup-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60rpx;
  }
  
  .popup-content {
    background: #FFFFFF;
    border-radius: 32rpx;
    width: 100%;
    max-height: 80vh;
    overflow: hidden;
    animation: slideUp 0.3s ease;
  }
  
  @keyframes slideUp {
    from { transform: translateY(60rpx); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  
  .popup-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx 36rpx;
    border-bottom: 1rpx solid #F0F2F5;
  }
  
  .popup-title {
    font-size: 34rpx;
    font-weight: bold;
    color: #2C3E50;
  }
  
  .popup-close {
    font-size: 36rpx;
    color: #95A5A6;
    padding: 10rpx;
  }
  
  .popup-body {
    padding: 30rpx 36rpx;
    max-height: 400rpx;
    overflow-y: auto;
  }
  
  .popup-desc {
    font-size: 28rpx;
    color: #7F8C8D;
    display: block;
    margin-bottom: 20rpx;
  }
  
  .popup-steps {
    background: #F5F7FA;
    border-radius: 16rpx;
    padding: 20rpx 24rpx;
  }
  
  .step-title {
    font-size: 26rpx;
    font-weight: 500;
    color: #2C3E50;
    display: block;
    margin-bottom: 12rpx;
  }
  
  .step-item {
    font-size: 24rpx;
    color: #4A5568;
    display: block;
    padding: 8rpx 0;
    line-height: 1.6;
  }
  
  .popup-footer {
    padding: 20rpx 36rpx 30rpx;
    border-top: 1rpx solid #F0F2F5;
  }
  
  .btn-enter {
    width: 100%;
    height: 80rpx;
    line-height: 80rpx;
    background: linear-gradient(135deg, #4A90D9, #357ABD);
    color: #FFFFFF;
    border-radius: 40rpx;
    font-size: 30rpx;
    border: none;
  }
  
  .btn-completed {
    width: 100%;
    height: 80rpx;
    line-height: 80rpx;
    background: #E8F8F0;
    color: #27AE60;
    border-radius: 40rpx;
    font-size: 30rpx;
    text-align: center;
  }

  /* 弹窗内完成状态 */
  .popup-status {
    background: #E8F8F0;
    border-radius: 12rpx;
    padding: 16rpx 20rpx;
    margin-top: 16rpx;
  }

  .status-completed {
    display: block;
    font-size: 28rpx;
    color: #27AE60;
    font-weight: 500;
  }

  .status-hint {
    display: block;
    font-size: 22rpx;
    color: #95A5A6;
    margin-top: 4rpx;
  }