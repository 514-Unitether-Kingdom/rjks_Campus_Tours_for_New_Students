page {
  background: #F5F7FA;
}

.map-container {
  padding: 40rpx 40rpx 60rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header-area {
  text-align: center;
  padding: 30rpx 0 36rpx;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 12rpx;
}

.page-subtitle {
  display: block;
  font-size: 28rpx;
  color: #7F8C8D;
}

.cache-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #E67E22;
}

.map-wrapper {
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.map-area {
  width: 100%;
  height: 680rpx;
  background: #E8EEF5;
  position: relative;
}

.map-movable {
  width: 100%;
  height: 680rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.map-image {
  width: 100%;
  height: 100%;
  display: block;
}

.map-placeholder {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 680rpx;
  background: #E8EEF5;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.placeholder-icon {
  font-size: 72rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #7F8C8D;
}

.retry-btn {
  width: 180rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  background: #4A90D9;
  color: #FFFFFF;
  font-size: 26rpx;
}

.retry-btn::after {
  border: none;
}

.map-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-top: 30rpx;
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #607D8B;
}

.disclaimer {
  text-align: center;
  margin-top: 40rpx;
}

.disclaimer-text {
  font-size: 22rpx;
  color: #B0BEC5;
}
