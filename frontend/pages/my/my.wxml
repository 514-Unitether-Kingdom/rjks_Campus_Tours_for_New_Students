<view class="my-container">
  <!-- 用户信息卡片 -->
  <view class="user-card">
    <view class="user-avatar-wrapper">
      <image class="user-avatar" 
             src="{{userInfo.avatarUrl}}" 
             mode="aspectFill">
      </image>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.name}}</text>
      <text class="user-detail">{{userInfo.college}} · {{userInfo.grade}}</text>
    </view>
  </view>

  <!-- 功能列表 -->
  <view class="menu-list">
    <view class="menu-item" bindtap="goProfile">
      <view class="menu-left">
        <text class="menu-icon">📝</text>
        <text class="menu-label">完善个人信息</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goBadges">
      <view class="menu-left">
        <text class="menu-icon">🏅</text>
        <text class="menu-label">我的勋章</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <view class="menu-item" bindtap="goAdminLogin">
      <view class="menu-left">
        <text class="menu-icon">🔐</text>
        <text class="menu-label">管理员登录</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>

    <!-- 登出按钮 -->
    <view class="menu-item menu-item-danger" bindtap="handleLogout">
      <view class="menu-left">
        <text class="menu-icon">🚪</text>
        <text class="menu-label menu-label-danger">退出登录</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text class="version-text">探校之旅 v1.0</text>
    <text class="version-text">北京工业大学 · 平乐园校区</text>
  </view>
</view>