page{background:#101d2b;color:#eaf0f5}.admin-page{min-height:100vh;padding:64rpx 30rpx;box-sizing:border-box}.eyebrow{display:block;font-size:19rpx;color:#8da4b9;letter-spacing:3rpx}.title{display:block;font-size:52rpx;font-weight:700;margin:16rpx 0}.subtitle{font-size:24rpx;color:#b4c4d0}.metrics{display:flex;margin:42rpx 0 30rpx;background:#172b3d;border:1rpx solid #29445d}.metrics view{flex:1;padding:22rpx 8rpx;text-align:center;border-right:1rpx solid #29445d}.metrics view:last-child{border:0}.metrics text,.metrics label{display:block}.metrics text{font-size:42rpx;color:#7fd1c3;font-weight:700}.metrics label{font-size:20rpx;color:#9eb0bd;margin-top:8rpx}.tabs{display:flex;border-bottom:1rpx solid #29445d;margin:20rpx 0}.tabs text{flex:1;padding:20rpx 0;text-align:center;color:#91a4b4}.tabs .active{color:#7fd1c3;border-bottom:4rpx solid #7fd1c3}.panel{background:#172b3d;padding:24rpx}.panel-head,.story-line,.user-row{display:flex;justify-content:space-between;gap:16rpx}.panel-head{padding-bottom:22rpx;border-bottom:1rpx solid #29445d;font-size:27rpx;font-weight:bold}.panel-head text:last-child{color:#7fd1c3;font-size:23rpx}.user-row,.story-row{padding:22rpx 0;border-bottom:1rpx solid #29445d}.user-row>text{font-size:19rpx;color:#8ea2b3}.user-name{display:block;font-size:27rpx;margin-bottom:7rpx}.user-row view text:last-child,.story-line view text:last-child{font-size:21rpx;color:#9eb0bd}.node-list{padding:8rpx 0 0;font-size:23rpx;line-height:1.7;color:#c4d0d9}.node-list text{color:#7fd1c3}.loading,.notice,.empty{padding:90rpx 16rpx;text-align:center;color:#aabac5}.retry{display:block;color:#7fd1c3;margin-top:18rpx}.logout{display:block;text-align:center;color:#d8877f;font-size:25rpx;margin:48rpx 0}
