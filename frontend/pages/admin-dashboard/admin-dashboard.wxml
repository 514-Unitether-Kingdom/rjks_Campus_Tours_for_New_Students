<view class="admin-page"><view class="admin-head"><text class="eyebrow">ADMIN / CONTROL ROOM</text><text class="title">校园数据台</text><text class="subtitle">只展示必要信息，所有数据均来自服务端。</text></view><view class="metrics"><view><text>{{stats.totalUsers}}</text><label>注册用户</label></view><view><text>{{stats.completedStories}}</text><label>完成剧情</label></view><view><text>{{stats.totalBadges}}</text><label>发放勋章</label></view></view><view class="loading" wx:if="{{loading}}">正在同步后台数据…</view><view class="notice" wx:elif="{{loadError}}"><text>{{loadError}}</text><text class="retry" bindtap="loadDashboard">重新加载</text></view><view wx:else><view class="tabs"><text class="{{activeTab === 'users' ? 'active' : ''}}" bindtap="switchTab" data-tab="users">用户</text><text class="{{activeTab === 'stories' ? 'active' : ''}}" bindtap="switchTab" data-tab="stories">剧情</text></view><view class="panel" wx:if="{{activeTab === 'users'}}"><view class="panel-head"><text>用户名册</text><text bindtap="exportUsers">导出 Excel ↗</text></view><view class="user-row" wx:for="{{users}}" wx:key="id"><view><text class="user-name">{{item.name || '未完善资料'}}</text><text>{{item.college || '—'}} · {{item.major || '—'}}</text></view><text>{{item.registerTime || '—'}}</text></view><view class="empty" wx:if="{{users.length === 0}}">暂无用户数据</view></view><view class="panel" wx:else><view class="panel-head"><text>剧情结构</text><text bindtap="exportStories">导出 TXT ↗</text></view><view class="story-row" wx:for="{{storyList}}" wx:key="id"><view class="story-line" bindtap="toggleStory" data-id="{{item.id}}"><view><text class="user-name">{{item.name}}</text><text>{{item.type}} · {{item.nodeCount}} 个节点 · {{item.status}}</text></view><text>{{item.expanded ? '−' : '+'}}</text></view><view class="node-list" wx:if="{{item.expanded}}"><view wx:for="{{item.nodes}}" wx:for-item="node" wx:key="id"><text>{{node.character || '系统'}}　</text>{{node.text}}</view></view></view></view></view><text class="logout" bindtap="logout">退出管理员会话</text></view>
