page {
    background: #F5F7FA;
  }
  
  .home-container {
    padding: 40rpx 40rpx 60rpx;
    min-height: 100vh;
  }
  
  /* ===== 头部 ===== */
  .header-area {
    padding: 30rpx 0 50rpx;
  }
  
  .user-greeting {
    display: flex;
    align-items: baseline;
    margin-bottom: 10rpx;
  }
  
  .greeting {
    font-size: 32rpx;
    color: #7F8C8D;
  }
  
  .username {
    font-size: 40rpx;
    font-weight: bold;
    color: #2C3E50;
    margin-left: 8rpx;
  }
  
  .welcome-text {
    font-size: 28rpx;
    color: #95A5A6;
  }
  
  /* ===== 菜单网格 ===== */
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30rpx;
    margin-top: 20rpx;
  }
  
  .menu-item {
    background: #FFFFFF;
    border-radius: 24rpx;
    padding: 40rpx 20rpx 30rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
    transition: transform 0.2s;
  }
  
  .menu-item:active {
    transform: scale(0.95);
  }
  
  .menu-icon-wrapper {
    width: 100rpx;
    height: 100rpx;
    border-radius: 24rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20rpx;
  }
  
  .menu-icon {
    width: 56rpx;
    height: 56rpx;
  }
  
  /* 图片加载失败时的fallback */
  .icon-text {
    font-size: 48rpx;
  }
  
  .menu-name {
    font-size: 30rpx;
    font-weight: 600;
    color: #2C3E50;
    margin-bottom: 6rpx;
  }
  
  .menu-desc {
    font-size: 22rpx;
    color: #B0BEC5;
  }
  
  /* ===== 底部 ===== */
  .footer-tip {
    margin-top: 60rpx;
    text-align: center;
  }
  
  .tip-text {
    font-size: 24rpx;
    color: #B0BEC5;
  }