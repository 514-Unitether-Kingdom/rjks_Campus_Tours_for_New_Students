page {
    background: #F5F7FA;
    height: 100vh;
    overflow: hidden;
  }
  
  .home-container {
    padding: 40rpx 40rpx 60rpx;
    height: 100vh;
    box-sizing: border-box;
  }
  
  /* ===== 头部 ===== */
  .header-area {
    padding: 30rpx 0 50rpx;
  }
  
  .user-greeting {
    display: flex;
    align-items: baseline;
    margin-bottom: 10rpx;
  }
  
  .greeting {
    font-size: 32rpx;
    color: #7F8C8D;
  }
  
  .username {
    font-size: 40rpx;
    font-weight: bold;
    color: #2C3E50;
    margin-left: 8rpx;
  }
  
  .welcome-text {
    font-size: 28rpx;
    color: #95A5A6;
  }
  
  /* ===== 菜单网格 ===== */
  .menu-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30rpx;
    margin-top: 20rpx;
  }
  
  .menu-item {
    background: #FFFFFF;
    border-radius: 24rpx;
    padding: 40rpx 20rpx 30rpx;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
    transition: transform 0.2s;
  }
  
  .menu-item:active {
    transform: scale(0.95);
  }
  
  .menu-icon-wrapper {
    width: 100rpx;
    height: 100rpx;
    border-radius: 24rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20rpx;
  }
  
  .menu-icon {
    width: 56rpx;
    height: 56rpx;
  }
  
  /* 图片加载失败时的fallback */
  .icon-text {
    font-size: 48rpx;
  }
  
  .menu-name {
    font-size: 30rpx;
    font-weight: 600;
    color: #2C3E50;
    margin-bottom: 6rpx;
  }
  
  .menu-desc {
    font-size: 22rpx;
    color: #B0BEC5;
  }
  
  /* ===== AI 助手入口卡片 ===== */
  .ai-entry {
    display: flex;
    align-items: center;
    margin-top: 36rpx;
    padding: 30rpx 30rpx;
    border-radius: 24rpx;
    background: linear-gradient(135deg, #4A90D9, #6CB4EE);
    box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.28);
  }
  .ai-entry-hover { transform: scale(0.98); }
  .ai-entry-icon {
    font-size: 56rpx;
    margin-right: 22rpx;
  }
  .ai-entry-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .ai-entry-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #FFFFFF;
  }
  .ai-entry-sub {
    font-size: 23rpx;
    color: rgba(255, 255, 255, 0.88);
    margin-top: 6rpx;
  }
  .ai-entry-arrow {
    font-size: 48rpx;
    color: rgba(255, 255, 255, 0.85);
    margin-left: 12rpx;
  }

  /* ===== 底部 ===== */
  .footer-tip {
    margin-top: 60rpx;
    text-align: center;
  }
  
  .tip-text {
    font-size: 24rpx;
    color: #B0BEC5;
  }
