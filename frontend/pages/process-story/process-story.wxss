/* 与 campus-story.wxss 内容相同，复制一份 */
.story-container {
    width: 100%;
    height: 100vh;
    position: relative;
    overflow: hidden;
    background: #1a1a2e;
  }
  
  .story-header {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 18rpx;
    box-sizing: border-box;
    min-height: 176rpx;
    padding: 108rpx 220rpx 22rpx 30rpx;
    background: linear-gradient(180deg, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.34) 68%, transparent 100%);
  }
  
  .header-left {
    min-width: 142rpx;
    height: 64rpx;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FFFFFF;
    background: rgba(0, 0, 0, 0.35);
    border: 1rpx solid rgba(255, 255, 255, 0.12);
    border-radius: 34rpx;
    padding: 0 18rpx 0 12rpx;
    box-sizing: border-box;
  }
  
  .back-icon {
    font-size: 44rpx;
    margin-right: 8rpx;
  }
  
  .back-text {
    font-size: 28rpx;
  }
  
  .header-title {
    flex: 1;
    min-width: 0;
    font-size: 30rpx;
    color: #FFFFFF;
    font-weight: 500;
    text-align: center;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .header-right {
    min-width: 142rpx;
    display: flex;
    justify-content: flex-end;
    flex-shrink: 0;
  }
  
  .header-right .hint {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 64rpx;
    min-width: 112rpx;
    box-sizing: border-box;
    font-size: 22rpx;
    color: rgba(255, 255, 255, 0.5);
    padding: 0 18rpx;
    background: rgba(0, 0, 0, 0.35);
    border: 1rpx solid rgba(255, 255, 255, 0.15);
    border-radius: 34rpx;
  }
  
  .story-body {
    width: 100%;
    height: 100%;
    position: relative;
  }
  
  .story-bg {
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
  }
  
  .story-character {
    position: absolute;
    bottom: 300rpx;
    right: 40rpx;
    width: 260rpx;
    height: 360rpx;
    z-index: 10;
  }
  
  .dialog-box {
    position: absolute;
    bottom: 40rpx;
    bottom: calc(40rpx + env(safe-area-inset-bottom));
    left: 30rpx;
    right: 30rpx;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(20rpx);
    border-radius: 24rpx;
    padding: 30rpx 36rpx;
    z-index: 20;
    min-height: 160rpx;
    border: 1rpx solid rgba(255, 255, 255, 0.08);
  }
  
  .dialog-name {
    font-size: 26rpx;
    color: #FFD700;
    font-weight: 500;
    margin-bottom: 10rpx;
  }
  
  .dialog-content {
    font-size: 30rpx;
    color: #FFFFFF;
    line-height: 1.8;
  }
  
  .dialog-tap-hint {
    text-align: center;
    margin-top: 14rpx;
    font-size: 22rpx;
    color: rgba(255, 255, 255, 0.3);
    letter-spacing: 4rpx;
  }
  
  .history-btn {
    position: absolute;
    bottom: 340rpx;
    bottom: calc(340rpx + env(safe-area-inset-bottom));
    right: 30rpx;
    z-index: 30;
    background: rgba(0, 0, 0, 0.5);
    border-radius: 30rpx;
    padding: 12rpx 24rpx;
    font-size: 24rpx;
    color: rgba(255, 255, 255, 0.7);
    border: 1rpx solid rgba(255, 255, 255, 0.1);
  }
