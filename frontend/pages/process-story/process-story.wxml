<view class="story-page"><image class="scene" src="{{currentNode.bg || '/images/story_bg_default.jpg'}}" mode="aspectFill"></image><view class="shade"></view><view class="topbar"><text data-testid="process-story-back" bindtap="goBack">← 离开</text><text class="map-entry" wx:if="{{currentNode.locationId}}" bindtap="toggleLocationMap">地点地图</text></view><image class="character" src="{{currentNode.characterImage}}" mode="aspectFit" wx:if="{{currentNode.characterImage}}"></image><view class="location-layer" wx:if="{{showLocationMap && currentNode.locationId}}" catchtap="toggleLocationMap"><view class="location-card" catchtap="preventClose"><text class="location-title">当前剧情地点</text><location-map location-id="{{currentNode.locationId}}"></location-map><text class="location-close" bindtap="toggleLocationMap">收起地图</text></view></view><view class="story-copy" data-testid="process-story-copy" bindtap="onTap"><text class="chapter-marker">FLOW / {{currentIndex + 1}}</text><text class="speaker">{{currentNode.character || '办事提示'}}</text><text class="words">{{currentNode.text}}</text><view class="choice-list" wx:if="{{currentNode.choices.length}}"><text class="choice-label">选择接下来要了解的内容</text><text class="choice" wx:for="{{currentNode.choices}}" wx:key="targetNodeId" catchtap="selectChoice" data-target="{{item.targetNodeId}}">{{item.text}}</text></view><view class="copy-foot"><text class="review" data-testid="process-story-previous" catchtap="goPrevious">上一页</text><text class="next" wx:if="{{isEnding}}">正在记录…</text><text class="next" wx:elif="{{currentNode.choices.length}}">请选择路线</text><text class="next" wx:elif="{{currentNode.isEnd}}">点击完成 →</text><text class="next" wx:else>轻触继续 →</text></view></view></view>
