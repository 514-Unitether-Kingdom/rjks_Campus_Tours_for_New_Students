<view class="saves-container">
  <view class="header-area">
    <text class="page-title">💾 存档管理</text>
    <text class="page-subtitle">最多保存 5 个存档</text>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <view class="saves-list" wx:elif="{{saves.length > 0}}">
    <view class="save-card" wx:for="{{saves}}" wx:key="slotId">
      <view class="save-card-main">
        <view class="save-title">
          <text class="save-icon">📖</text>
          <text class="save-story">{{item.storyName || '浏览校园'}}</text>
        </view>

        <view class="save-meta">
          <text class="save-pill">第 {{item.nodeIndex || 0}} 节</text>
          <text class="save-time">{{item.saveTime}}</text>
        </view>

        <text class="save-summary">{{item.nodeSummary || '暂无节点摘要'}}</text>
      </view>

      <view class="save-actions">
        <button class="save-action-btn btn-load" bindtap="loadSave" data-id="{{item.slotId}}">载入</button>
        <button class="save-action-btn btn-delete" bindtap="deleteSave" data-id="{{item.slotId}}">删除</button>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">📭</text>
    <text class="empty-title">暂无存档记录</text>
    <text class="empty-desc">在浏览校园剧情中点击「存档」即可保存进度</text>
  </view>
</view>
