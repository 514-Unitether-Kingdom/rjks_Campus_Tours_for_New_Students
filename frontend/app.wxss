/* 全局样式 */
page {
    background-color: #F5F7FA;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  .container {
    padding: 20rpx;
    min-height: 100vh;
  }
  .btn-primary {
    background: #4A90D9;
    color: #fff;
    border-radius: 40rpx;
    padding: 20rpx 40rpx;
    font-size: 32rpx;
    border: none;
  }
  .btn-primary:active {
    opacity: 0.8;
  }